# AthenaK input file for dyn_radiation nonlinear source-iteration test

<job>
basename = dynrad_source_iteration

<mesh>
nghost = 2
nx1 = 4
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 4
nx2 = 1
nx3 = 1

<coord>
general_rel = true
minkowski = true

<time>
evolution = dynamic
integrator = rk1
cfl_number = 0.3
nlim = 1
tlim = 1.0

<hydro>
eos = ideal
reconstruct = plm
rsolver = hlle
gamma = 1.6666666666666667

<dyn_radiation>
geometry = cks
nlevel = 0
rotate_geo = false
angular_fluxes = false
reconstruct = plm
rad_source = true
fixed_fluid = true
affect_fluid = false
power_opacity = true
kappa_a = 1000.0
kappa_s = 0.0
kappa_p = 0.0
arad = 1.0
source_max_iter = 16
source_tolerance = 1.0e-12

<problem>
pgen_name = rad_linear_wave
source_iteration_test = true
rho = 1.0
pgas = 5.0e-2
erad = 1.0e1
min_rad_change = 1.0e-1
max_rad_change = 2.0
