# AthenaK input file for ADM dyn_radiation momentum-source closure test

<job>
basename = dynrad_momentum_source

<mesh>
nghost = 2
nx1 = 128
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 4
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 64
nx2 = 4
nx3 = 1

<coord>
general_rel = true
minkowski = true

<adm>
dynamic = false

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.3
nlim = 0
tlim = 0.0

<dyn_radiation>
geometry = adm
nlevel = 3
rotate_geo = false
angular_fluxes = true
reconstruct = plm

<problem>
pgen_name = rad_momentum_source
erad = 1.0
flux_fraction = 0.45
alpha_amp = 0.05
beta_amp = 0.04
metric_amp = 0.03
metric_k = 6.283185307179586
momentum_abs_tolerance = 2.0e-6
momentum_rel_tolerance = 1.0e-3

<output1>
file_type = bin
variable = rad_coord
id = rad_xy
dt = 1.0
slice_x3 = 0.5
