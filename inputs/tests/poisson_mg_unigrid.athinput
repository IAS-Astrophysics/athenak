# Scalar Poisson multigrid manufactured-solution smoke test.

<job>
basename  = poisson_mg_unigrid

<mesh>
nghost    = 2
nx1       = 16
x1min     = 0.0
x1max     = 1.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 16
x2min     = 0.0
x2max     = 1.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 16
x3min     = 0.0
x3max     = 1.0
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 16
nx2       = 16
nx3       = 16

<time>
evolution  = static
cfl_number = 0.2
nlim       = 0
tlim       = 0.0
ndiag      = 1

<hydro>
eos         = ideal
reconstruct = plm
rsolver     = advect
gamma       = 1.66666666667

<gravity>
four_pi_G = 1.0
threshold = -1.0
niteration = 3
npresmooth = 2
npostsmooth = 2
omega = 1.0
show_defect = true
subtract_average = true
full_multigrid = false
mg_nghost = 2

<poisson_test>
enabled = true
composite_fas = false
manufactured = sin
debug_residual = true
debug_masks = false
debug_composite_masks = true
debug_residual_split = true
debug_boundary_contract = false
scalar_boundary_contract = none
amplitude = 1.0e-3
density_offset = 1.0
waves = 1
pressure = 1.0

<problem>
pgen_name = poisson_mg_test
