# AthenaK input file for MHD linear wave tests with SMR and binary divB diagnostics

<comment>
problem   = mhd linear waves with smr divb diagnostics

<job>
basename  = LinWaveSMRDivB

<mesh>
nghost    = 2
nx1       = 64
x1min     = 0.0
x1max     = 3.0
ix1_bc    = periodic
ox1_bc    = periodic

nx2       = 32
x2min     = 0.0
x2max     = 1.5
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 32
x3min     = 0.0
x3max     = 1.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 16
nx2       = 8
nx3       = 8

<mesh_refinement>
refinement = static

<refined_region1>
level = 1
x1min = 1.4
x1max = 1.6
x2min = 0.7
x2max = 0.8
x3min = 0.7
x3max = 0.8

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = -1
tlim       = 0.5
ndiag      = 1

<mhd>
eos         = ideal
reconstruct = plm
rsolver     = llf
gamma       = 1.66666666667

<problem>
pgen_name = linear_wave
wave_flag = 0
amp       = 1.0e-3
dens      = 1.0
pgas      = 0.6
vx0       = 0.0
vy0       = 0.0
vz0       = 0.0
bx0       = 1.0
by0       = 1.4142136
bz0       = 0.5
along_x1  = false
along_x2  = false
along_x3  = false

<output1>
file_type   = bin
variable    = mhd_divb
dt          = 0.05
ghost_zones = true

<output2>
file_type   = bin
variable    = mhd_w_bcc
dt          = 0.05
ghost_zones = true

<output3>
file_type   = hst
data_format = %12.5e
dt          = 0.1
