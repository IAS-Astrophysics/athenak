# AthenaK input file for multilevel Hydro STS viscosity smoke coverage

<comment>
problem  = viscous diffusion with static mesh refinement

<job>
basename = STSViscSMR

<mesh>
nghost    = 4
nx1       = 128
x1min     = -5.0
x1max     = 5.0
ix1_bc    = user
ox1_bc    = user

nx2       = 1
x2min     = -0.5
x2max     = 0.5
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 1
x3min     = -0.5
x3max     = 0.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 32
nx2       = 1
nx3       = 1

<mesh_refinement>
refinement = static

<refined_region1>
level = 1
x1min = -1.0
x1max = 1.0

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.4
nlim       = 4
tlim       = 0.1
ndiag      = 1
sts_integrator = rkl2
sts_max_dt_ratio = -1.0

<hydro>
eos         = ideal
reconstruct = wenoz
rsolver     = hllc
gamma       = 1.66667
viscosity   = 1.0
viscosity_integrator = sts

<problem>
pgen_name = diffusion
diffusion_test = hydro_viscosity
amp    = 1.e-6
t0     = 0.5
x10    = 0.0

<output1>
file_type = hst
dt        = 0.01
