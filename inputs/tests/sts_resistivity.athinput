# AthenaK input file for exact Ohmic diffusion test

<comment>
problem  = resistive diffusion

<job>
basename = ResistiveDiffusion

<mesh>
nghost    = 3
nx1       = 128
x1min     = -5.0
x1max     = 5.0
ix1_bc    = user
ox1_bc    = user

nx2       = 1
x2min     = -0.5
x2max     = 0.5
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 1
x3min     = -0.5
x3max     = 0.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 32
nx2       = 1
nx3       = 1

<time>
evolution  = kinematic
integrator = rk2
cfl_number = 0.4
nlim       = -1
tlim       = 4.0
ndiag      = 1
sts_integrator = none
sts_max_dt_ratio = -1.0

<mhd>
eos               = isothermal
reconstruct       = plm
rsolver           = advect
iso_sound_speed   = 1.0
ohmic_resistivity = 1.0
ohmic_resistivity_integrator = explicit

<problem>
pgen_name = diffusion
diffusion_test = mhd_resistivity
amp    = 1.e-6
t0     = 0.5
x10    = 0.0

<output1>
file_type = hst
dt        = 0.01
