# AthenaK input file for dyn_radiation conservative angular positivity limiter test

<job>
basename = dynrad_positivity_floor

<mesh>
nghost = 2
nx1 = 4
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 1
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 4
nx2 = 1
nx3 = 1

<coord>
general_rel = true
minkowski = true

<adm>
dynamic = false

<time>
evolution = dynamic
integrator = rk1
cfl_number = 0.3
nlim = 1
tlim = 1.0

<dyn_radiation>
geometry = cks
nlevel = 0
rotate_geo = false
angular_fluxes = false
reconstruct = plm

<problem>
pgen_name = rad_beam
positivity_floor_test = true
