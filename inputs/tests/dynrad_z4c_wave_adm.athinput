# AthenaK input file for a compact dyn_radiation smoke test on a dynamic
# Z4c/ADM linear-wave background.

<job>
basename = dynrad_z4c_wave_adm

<mesh>
nghost = 3
nx1 = 8
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic
nx2 = 8
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic
nx3 = 8
x3min = 0.0
x3max = 1.0
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 8
nx2 = 8
nx3 = 8

<time>
evolution = dynamic
integrator = rk2
cfl_number = 0.3
nlim = -1
tlim = 0.02
ndiag = 1

<z4c>
diss = 1

<dyn_radiation>
geometry = adm
nlevel = 1
rotate_geo = false
angular_fluxes = true
reconstruct = dc

<rad_srcterms>
rad_beam = true
dii_dt = 1.0
pos_1 = 0.25
pos_2 = 0.25
pos_3 = 0.25
dir_1 = 1.0
dir_2 = 0.0
dir_3 = 0.0
width = 0.1
spread = 20.0

<problem>
pgen_name = z4c_linear_wave
amp = 1.0e-8
kx1 = 1
kx2 = 1
kx3 = 1

<output1>
file_type = tab
variable = rad_coord
data_format = %.16e
dt = 0.02
slice_x1 = 0.25
slice_x3 = 0.25
ghost_zones = false
